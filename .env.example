# Public site origin — drives metadataBase, canonical URLs, sitemap, and JSON-LD.
# No trailing slash. Set this in Vercel (Production + Preview) to the live domain.
# Falls back to https://thebigartcalendar.com when unset (see src/lib/site.ts).
NEXT_PUBLIC_SITE_URL=https://thebigartcalendar.com

# Neon database connection string
# Get this from your Neon project dashboard: https://console.neon.tech
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Blob — image hosting for event overrides and blog images.
# Added automatically by `vercel blob create-store` / `vercel env pull`.
# Manage or rotate in the Vercel dashboard → Storage → Blob.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Shared secret for the admin image-upload route (POST /api/admin/upload).
# Generate with: openssl rand -hex 32
# Retool sends it as the header: Authorization: Bearer <token>
ADMIN_UPLOAD_TOKEN=